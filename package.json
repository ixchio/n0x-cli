{
  "name": "@n0x/n0x",
  "version": "0.1.0",
  "description": "n0x — local-first terminal coding agent powered by Bonsai",
  "type": "module",
  "bin": {
    "n0x": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepublishOnly": "npm run check && npm run build"
  },
  "keywords": [
    "n0x",
    "cli",
    "agent",
    "bonsai",
    "coding-agent",
    "local-first"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ixchio/n0x-cli.git"
  },
  "homepage": "https://github.com/ixchio/n0x-cli#readme",
  "bugs": {
    "url": "https://github.com/ixchio/n0x-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@tavily/core": "^0.7.5",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "diff": "^7.0.0",
    "glob": "^11.0.2",
    "smol-toml": "^1.6.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/diff": "^7.0.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.0",
    "vitest": "^3.0.8"
  }
}
