{
  "name": "n0x-cli",
  "version": "0.8.2",
  "description": "n0x-cli — Claude Code quality for 4GB systems, powered by Bonsai",
  "type": "module",
  "bin": {
    "n0x": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check",
    "download-binaries": "node scripts/download-llama-binaries.js",
    "package": "npm pack"
  },
  "keywords": [
    "n0x",
    "cli",
    "agent",
    "bonsai",
    "coding-agent",
    "local-first"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ixchio/n0x-cli.git"
  },
  "homepage": "https://github.com/ixchio/n0x-cli#readme",
  "bugs": {
    "url": "https://github.com/ixchio/n0x-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@tavily/core": "^0.7.6",
    "adm-zip": "^0.5.18",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "diff": "^9.0.0",
    "glob": "^13.0.6",
    "markstream-cli": "^0.0.2",
    "smol-toml": "^1.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^22.20.0",
    "eslint": "^9.22.0",
    "tsx": "^4.23.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
